__pycache__/
*.py[cod]
*.egg-info/
# build/ holds PyInstaller spec + scripts (tracked) plus the per-build
# work dir (.pyinstaller/, generated). Track the sources, ignore the
# work dir + any sibling .cache/.
build/.pyinstaller/
build/.cache/
dist/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# User batches are data, not source — ignore everything except the placeholder
batches/*
!batches/.gitkeep
*.local.yaml

# OS
.DS_Store
Thumbs.db

# Office lock files
~$*

# Input data — raw images and catalogue spreadsheets live here but don't belong in VCS
source/

# Sheet-check editable working copies — disposable, per-machine
scratch/

# Claude Code local settings
.claude/settings.local.json

# Test fixture run artifacts (keep the source fixtures, ignore generated outputs)
tests/fixtures/**/processed/
tests/fixtures/**/review/
tests/fixtures/**/_report_assets/
tests/fixtures/**/report.html
